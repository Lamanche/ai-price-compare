# Required: Get a free API key at https://openrouter.ai/keys (no credit card needed)
OPENROUTER_API_KEY=

# Optional: Jina AI Reader key for the daily subscription price bot
# Get free at https://jina.ai — also add as GitHub Actions secret JINA_API_KEY
# Without this key the bot still works but at a lower rate limit (20 RPM vs 100 RPM)
JINA_API_KEY=

# Optional: Override the canonical site URL used in metadata and sitemap
NEXT_PUBLIC_SITE_URL=https://your-domain.com
